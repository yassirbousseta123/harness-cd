{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "thread_id": {
          "type": "string"
        },
        "submission_id": {
          "type": "string"
        },
        "comment_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "subreddit": {
          "type": "string"
        },
        "quote": {
          "type": "string"
        },
        "why_it_supports": {
          "type": "string"
        }
      },
      "required": [
        "thread_id",
        "submission_id",
        "comment_id",
        "subreddit",
        "quote",
        "why_it_supports"
      ]
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        }
      },
      "required": [
        "label",
        "summary",
        "confidence",
        "evidence"
      ]
    },
    "summary_field": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        }
      },
      "required": [
        "summary",
        "confidence",
        "evidence"
      ]
    },
    "demographic_field": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "notes": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        }
      },
      "required": [
        "value",
        "confidence",
        "notes",
        "evidence"
      ]
    },
    "desire_chain": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "i_want_to": {
          "type": "string"
        },
        "so_i_can_1": {
          "type": "string"
        },
        "so_i_can_2": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        }
      },
      "required": [
        "i_want_to",
        "so_i_can_1",
        "so_i_can_2",
        "summary",
        "confidence",
        "evidence"
      ]
    },
    "language_item": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "phrase": {
          "type": "string"
        },
        "why_it_matters": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        }
      },
      "required": [
        "phrase",
        "why_it_matters",
        "confidence",
        "evidence"
      ]
    }
  },
  "properties": {
    "avatar_explanation": {
      "$ref": "#/$defs/summary_field"
    },
    "age": {
      "$ref": "#/$defs/demographic_field"
    },
    "gender": {
      "$ref": "#/$defs/demographic_field"
    },
    "pain_points": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "day_to_day_struggles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "victories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "failures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "goals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "beliefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "desires": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/desire_chain"
      }
    },
    "objections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "level_of_awareness": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stage": {
          "type": "string",
          "enum": [
            "completely_unaware",
            "problem_aware",
            "solution_aware",
            "product_aware",
            "most_aware"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        }
      },
      "required": [
        "stage",
        "rationale",
        "confidence",
        "evidence"
      ]
    },
    "emotions_identity": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "real_customer_language": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/language_item"
      }
    },
    "visual_cues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "trigger_moments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "source_coverage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "threads_reviewed": {
          "type": "integer",
          "minimum": 0
        },
        "packs_reviewed": {
          "type": "integer",
          "minimum": 0
        },
        "subreddits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "earliest_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "latest_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "threads_reviewed",
        "packs_reviewed",
        "subreddits",
        "earliest_date",
        "latest_date",
        "notes"
      ]
    },
    "gaps_and_unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "avatar_explanation",
    "age",
    "gender",
    "pain_points",
    "day_to_day_struggles",
    "victories",
    "failures",
    "goals",
    "beliefs",
    "desires",
    "objections",
    "level_of_awareness",
    "emotions_identity",
    "real_customer_language",
    "visual_cues",
    "trigger_moments",
    "source_coverage",
    "gaps_and_unknowns"
  ]
}
