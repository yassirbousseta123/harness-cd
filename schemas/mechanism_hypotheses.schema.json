{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "thread_id": {
          "type": "string"
        },
        "submission_id": {
          "type": "string"
        },
        "comment_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "subreddit": {
          "type": "string"
        },
        "quote": {
          "type": "string"
        },
        "why_it_supports": {
          "type": "string"
        }
      },
      "required": [
        "thread_id",
        "submission_id",
        "comment_id",
        "subreddit",
        "quote",
        "why_it_supports"
      ]
    },
    "mechanism": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string"
        },
        "mechanism_type": {
          "type": "string",
          "enum": [
            "market",
            "identity",
            "scientific"
          ]
        },
        "concise_statement": {
          "type": "string"
        },
        "why_it_resonates": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "supporting_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "proof_required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "disconfirming_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risk_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "label",
        "mechanism_type",
        "concise_statement",
        "why_it_resonates",
        "confidence",
        "supporting_evidence",
        "proof_required",
        "disconfirming_signals",
        "risk_flags"
      ]
    },
    "offer_hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string"
        },
        "offer_frame": {
          "type": "string"
        },
        "problem_it_meets": {
          "type": "string"
        },
        "awareness_fit": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "supporting_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "proof_required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risk_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "label",
        "offer_frame",
        "problem_it_meets",
        "awareness_fit",
        "confidence",
        "supporting_evidence",
        "proof_required",
        "risk_flags"
      ]
    }
  },
  "properties": {
    "avatar_name": {
      "type": "string"
    },
    "mechanism_theses": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mechanism"
      }
    },
    "offer_hypotheses": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/offer_hypothesis"
      }
    },
    "gaps_and_unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compliance_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "avatar_name",
    "mechanism_theses",
    "offer_hypotheses",
    "gaps_and_unknowns",
    "compliance_notes"
  ]
}
