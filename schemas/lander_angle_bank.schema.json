{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "thread_id": {
          "type": "string"
        },
        "submission_id": {
          "type": "string"
        },
        "comment_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "subreddit": {
          "type": "string"
        },
        "quote": {
          "type": "string"
        },
        "why_it_supports": {
          "type": "string"
        }
      },
      "required": [
        "thread_id",
        "submission_id",
        "comment_id",
        "subreddit",
        "quote",
        "why_it_supports"
      ]
    },
    "lander_angle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "angle_name": {
          "type": "string"
        },
        "big_idea": {
          "type": "string"
        },
        "opening_move": {
          "type": "string"
        },
        "emotional_job": {
          "type": "string"
        },
        "proof_stack": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "objection_handling": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cta_theme": {
          "type": "string"
        },
        "awareness_fit": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "risk_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "angle_name",
        "big_idea",
        "opening_move",
        "emotional_job",
        "proof_stack",
        "objection_handling",
        "cta_theme",
        "awareness_fit",
        "confidence",
        "evidence",
        "risk_flags"
      ]
    }
  },
  "properties": {
    "avatar_name": {
      "type": "string"
    },
    "lander_angles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lander_angle"
      }
    },
    "gaps_and_unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "avatar_name",
    "lander_angles",
    "gaps_and_unknowns"
  ]
}
